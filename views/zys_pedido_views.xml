<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista Lista -->
    <record id="view_x_zys_pedido_list" model="ir.ui.view">
        <field name="name">x_zys_pedido.list</field>
        <field name="model">x_zys_pedido</field>
        <field name="priority">16</field>
        <field name="arch" type="xml">
            <list string="Pedidos ZYS"
                  decoration-danger="x_status=='PENDIENTE'"
                  decoration-warning="x_status=='PEDIDO'"
                  decoration-info="x_status=='RECIBIDO'"
                  decoration-success="x_status in ['RETIRADO','PAGADO']">
                <field name="x_fecha"/>
                <field name="x_matricula"/>
                <field name="x_marca"/>
                <field name="x_cliente_id"/>
                <field name="x_product_id"/>
                <field name="x_descripcion"/>
                <field name="x_cantidad"/>
                <field name="x_precio"/>
                <field name="x_status" widget="badge"
                       decoration-danger="x_status=='PENDIENTE'"
                       decoration-warning="x_status=='PEDIDO'"
                       decoration-info="x_status=='RECIBIDO'"
                       decoration-success="x_status in ['RETIRADO','PAGADO']"
                       decoration-muted="x_status in ['ANULADO','DEVOLUCION']"/>
                <field name="x_dependiente_id"/>
                <field name="x_sale_order_id" optional="show"/>
            </list>
        </field>
    </record>

    <!-- Vista Formulario -->
    <record id="view_x_zys_pedido_form" model="ir.ui.view">
        <field name="name">x_zys_pedido.form</field>
        <field name="model">x_zys_pedido</field>
        <field name="priority">16</field>
        <field name="arch" type="xml">
            <form string="Pedido ZYS">
                <header>
                    <!-- Botón: Imprimir Ticket -->
                    <button name="%(zys_gestor_pedidos.action_report_zys_ticket)d"
                            string="🖨️ Imprimir Ticket"
                            type="action"
                            class="btn-secondary"/>
                    <!-- Botón principal: cambia estado a PEDIDO + crea presupuesto + lo abre -->
                    <button name="%(zys_gestor_pedidos.action_server_zys_crear_presupuesto)d"
                            string="📦 Marcar como PEDIDO y Crear Presupuesto"
                            type="action"
                            class="btn-primary"
                            invisible="x_status != 'PENDIENTE'"/>
                    <!-- Barra de progreso del estado (solo visual, sin clickar PEDIDO) -->
                    <field name="x_status" widget="statusbar"
                           statusbar_visible="PENDIENTE,PEDIDO,RECIBIDO,RETIRADO,PAGADO"
                           options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <!-- Cinta de estado visual -->
                    <widget name="web_ribbon" title="Pedido"   bg_color="bg-warning" invisible="x_status != 'PEDIDO'"/>
                    <widget name="web_ribbon" title="Recibido" bg_color="bg-info"    invisible="x_status != 'RECIBIDO'"/>
                    <widget name="web_ribbon" title="Retirado" bg_color="bg-success" invisible="x_status not in ['RETIRADO','PAGADO']"/>
                    <widget name="web_ribbon" title="Anulado"  bg_color="bg-danger"  invisible="x_status not in ['ANULADO','DEVOLUCION']"/>



                    <div class="oe_title">
                        <label for="x_matricula" string="Matrícula del Vehículo"/>
                        <h1>
                            <field name="x_matricula" placeholder="Ej: 1234 ABC"/>
                        </h1>
                        <h3>
                            <field name="x_marca" placeholder="Marca del vehículo"/>
                        </h3>
                    </div>

                    <group>
                        <group string="Cliente">
                            <field name="x_cliente_id"
                                   options="{'quick_create': True}"
                                   placeholder="Busca o crea un contacto..."/>
                            <field name="x_telefono" placeholder="Teléfono"/>
                        </group>
                        <group string="Estado y Gestión">
                            <field name="x_fecha"/>
                            <field name="x_dependiente_id"/>
                            <field name="x_status"/>
                        </group>
                    </group>

                    <group string="Pieza / Producto">
                        <group>
                            <field name="x_product_id"
                                   options="{'quick_create': True}"
                                   placeholder="Busca o crea un producto..."/>
                            <field name="x_descripcion" placeholder="Descripción personalizada"/>
                            <field name="x_referencia"  placeholder="Referencia / OEM"/>
                        </group>
                        <group>
                            <field name="x_cantidad"/>
                            <field name="x_precio"/>
                            <field name="x_proveedor_id"
                                   options="{'quick_create': True}"
                                   placeholder="Proveedor donde se pide"/>
                        </group>
                    </group>

                    <group string="Observaciones">
                        <field name="x_situacion" nolabel="1" placeholder="Notas internas..."/>
                    </group>

                    <!-- Presupuesto vinculado (visible solo cuando ya es PEDIDO o superior) -->
                    <group invisible="not x_sale_order_id or x_status == 'PENDIENTE'">
                        <field name="x_sale_order_id" readonly="1" string="Presupuesto creado"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Acción -->
    <record id="action_x_zys_pedido" model="ir.actions.act_window">
        <field name="name">Pedidos ZYS</field>
        <field name="res_model">x_zys_pedido</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menús -->
    <menuitem id="menu_x_zys_pedidos_root" name="Gestor ZYS" sequence="90"/>
    <menuitem id="menu_x_zys_pedidos"
              name="Pedidos"
              parent="menu_x_zys_pedidos_root"
              action="action_x_zys_pedido"
              sequence="10"/>

    <!-- Acción: abrir presupuestos de Ventas creados desde ZYS -->
    <record id="action_x_zys_presupuestos" model="ir.actions.act_window">
        <field name="name">Presupuestos ZYS</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('origin', 'like', 'ZYS -')]</field>
        <field name="context">{'search_default_draft': 1}</field>
    </record>

    <menuitem id="menu_x_zys_presupuestos"
              name="Presupuestos"
              parent="menu_x_zys_pedidos_root"
              action="action_x_zys_presupuestos"
              sequence="20"/>

</odoo>
